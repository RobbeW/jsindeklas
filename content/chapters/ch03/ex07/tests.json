  },
  {
    "label": "Uitstekende score",
    "stdout": "Uitstekend.",
    "replacements": [
      {
        "pattern": "\\b(?:var|let|const)\\s+score\\s*=\\s*14\\s*;?(?:\\s*//[^\\n]*)?",
        "to": "var score = 18;"
      }
    ]
  },
  {
    "label": "Onvoldoende score",
    "stdout": "Onvoldoende.",
    "replacements": [
      {
        "pattern": "\\b(?:var|let|const)\\s+score\\s*=\\s*14\\s*;?(?:\\s*//[^\\n]*)?",
        "to": "var score = 7;"
      }
    ]
  }
]
